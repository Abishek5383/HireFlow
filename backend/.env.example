# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/smart_hr_recruitment

# JWT security configuration
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP configuration for interview emails (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM_NAME="Smart HR Recruiter"

# Server configuration
HOST=0.0.0.0
PORT=8000
