frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# General/IDE/OS
.vscode/
.idea/
.gemini/
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
